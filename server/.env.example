# Conexión a PostgreSQL (Railway la provee como DATABASE_URL)
# Local con docker compose: postgresql://postgres:postgres@localhost:5432/cuentaclara
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cuentaclara"

# Secreto para firmar los JWT. Usa una cadena larga y aleatoria en producción.
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# Puerto del servidor (Railway inyecta PORT automáticamente)
PORT=4000

# Origen permitido para CORS (URL del frontend). Varios separados por coma.
# Ej: https://cuentaclara.netlify.app,http://localhost:5173
CORS_ORIGIN="http://localhost:5173"
